@model PlataformaCreditos.Models.ViewModels.NuevaSolicitudViewModel

@{ ViewData["Title"] = "Nueva Solicitud de Crédito"; }

<h2>Nueva Solicitud de Crédito</h2>

@if (Model.Mensaje != null)
{
    <div class="alert @(Model.Exito ? "alert-success" : "alert-danger")">
        @Model.Mensaje
    </div>
}

<form method="post" asp-action="Nueva">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="MontoSolicitado" class="form-label"></label>
        <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Enviar Solicitud</button>
    <a asp-action="MisSolicitudes" class="btn btn-secondary">Ver Mis Solicitudes</a>
</form>